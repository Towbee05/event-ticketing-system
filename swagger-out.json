        ],
        "summary": "Refresh access token",
        "description": "Exchange a valid refresh token for a new access token and a new refresh token (token rotation)",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "Refresh token",
            "schema": {
              "type": "object",
              "properties": {
