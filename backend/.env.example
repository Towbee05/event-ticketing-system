# Copy to .env and fill in the values.

PORT=5000
MONGO_URI=mongodb://localhost:27017/event-ticketing

# Use the bundled in-memory MongoDB instead of MONGO_URI (dev only).
USE_MEMORY_DB=false

# JWT — generate with `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Comma-separated list of allowed origins (frontend dev server etc.)
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Used to build payment callback URLs and password reset links.
FRONTEND_URL=http://localhost:5174

# Paystack — leave blank to use the dev-mode mock that auto-confirms.
PAYSTACK_SECRET_KEY=

# Email transport (SMTP). Leave blank to log to stdout in dev.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Eventu <no-reply@example.com>"

# Cloudinary (optional, only if uploading profile/event images)
CLOUD_NAME=
CLOUD_SECRET_KEY=
CLOUD_API_KEY=
